<Page x:Class="Praktiaka2.Views.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="StartPage">
    <Grid Background="#F0F2F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Вітаємо у квесті!" FontSize="28" FontWeight="Bold" Margin="0,0,0,30" Foreground="#1A73E8"/>
            <Button Content="Почати гру" Width="200" Height="50" FontSize="18" 
                    Background="#34A853" Foreground="White" Click="StartGame_Click"/>
        </StackPanel>
    </Grid>
</Page>