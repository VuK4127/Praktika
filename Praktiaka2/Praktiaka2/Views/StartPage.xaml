<Page x:Class="Praktiaka2.Views.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="StartPage">

    <Grid Background="{DynamicResource WindowBackground}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="МОВНИЙ КВЕСТ" FontSize="48" FontWeight="Bold" 
                       Foreground="{DynamicResource MainTextBrush}" Margin="0,0,0,30"/>

            <Button Content="ПОЧАТИ ГРУ" Style="{StaticResource MainButtonStyle}" 
                    Background="#1A73E8" Width="200" Margin="10" Click="Start_Click"/>

            <Button Content="ЗМІНИТИ ТЕМУ 🌓" Style="{StaticResource MainButtonStyle}" 
                    Background="#6C757D" Width="200" Margin="10" Click="ThemeToggle_Click"/>
        </StackPanel>
    </Grid>
    
</Page>