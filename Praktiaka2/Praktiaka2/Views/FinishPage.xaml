<Page x:Class="Praktiaka2.Views.FinishPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Результати">

    <Grid Background="#F0F2F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="КВЕСТ ЗАВЕРШЕНО!" 
                       FontSize="36" FontWeight="ExtraBold" 
                       Foreground="{StaticResource SuccessGreenBrush}" 
                       Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock x:Name="ResultText" 
                       Text="Завантаження результатів..." 
                       FontSize="24" TextWrapping="Wrap" 
                       TextAlignment="Center" Margin="0,0,0,40" 
                       Foreground="#495057"/>

            <Button Content="ПОВЕРНУТИСЯ В МЕНЮ" 
                    Style="{StaticResource MainButtonStyle}" 
                    Background="{StaticResource PrimaryBlueBrush}" 
                    Width="250" Click="ToMenu_Click"/>

        </StackPanel>
    </Grid>
</Page>