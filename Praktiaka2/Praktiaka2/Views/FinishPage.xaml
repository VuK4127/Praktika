<Page x:Class="Praktiaka2.Views.FinishPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Кінець гри">

    <Grid Background="{DynamicResource WindowBackground}">
        <Border Background="{DynamicResource CardBackground}" CornerRadius="15" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="ГРУ ЗАВЕРШЕНО!" FontSize="28" Foreground="#34A853" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ResultText" Text="Результат" FontSize="20" Foreground="{DynamicResource MainTextBrush}" Margin="0,20"/>
                <Button Content="В МЕНЮ" Click="ToMenu_Click" Style="{StaticResource MainButtonStyle}" Background="#1A73E8"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>