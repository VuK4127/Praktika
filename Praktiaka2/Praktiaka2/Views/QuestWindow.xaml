<Window x:Class="Praktiaka2.Views.QuestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Praktiaka2.Views"
        mc:Ignorable="d"
        Title="QuestWindow" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="QuestionText" Text="Тут буде питання" FontSize="20" Margin="10" TextWrapping="Wrap" TextAlignment="Center"/>
            <TextBox x:Name="AnswerInput" Width="200" Margin="10" FontSize="16"/>
            <Button Content="Відповісти" Width="100" Height="30" Click="Submit_Click" Background="#FF2196F3" Foreground="White"/>
            <TextBlock x:Name="ResultText" Margin="10" FontSize="14" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
