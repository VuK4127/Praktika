<Page x:Class="Praktiaka2.Views.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Praktiaka2.ViewModels"
      Title="GamePage">

    <Page.DataContext>
        <vm:QuestViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <TextBlock Text="{Binding ActiveQuestionText}" FontSize="22" FontWeight="Medium" 
                       TextWrapping="Wrap" TextAlignment="Center" Foreground="#212529"/>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" MaxWidth="500">
            <TextBlock Text="Ваша відповідь:" Margin="0,0,0,10" FontWeight="SemiBold" Foreground="#495057"/>
            <TextBox x:Name="AnswerInput" Height="45" FontSize="18" Padding="10,5" 
                     VerticalContentAlignment="Center" Background="White"/>
        </StackPanel>

        <UniformGrid Grid.Row="2" Columns="2" HorizontalAlignment="Center">
            <Button x:Name="CheckBtn" Content="ПЕРЕВІРИТИ" Width="180" Height="50" Margin="10" 
                    Background="#34A853" Foreground="White" FontWeight="Bold" FontSize="14" 
                    Cursor="Hand" Click="CheckBtn_Click"/>

            <Button x:Name="NextBtn" Content="НАСТУПНЕ" Width="180" Height="50" Margin="10" 
                    Background="#FBBC05" Foreground="White" FontWeight="Bold" FontSize="14" 
                    Cursor="Hand" Click="NextBtn_Click" IsEnabled="False"/>
        </UniformGrid>
    </Grid>
</Page>