<Page x:Class="Praktiaka2.Views.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Praktiaka2.ViewModels"
      Title="Гра">

    <Page.DataContext>
        <vm:QuestViewModel/>
    </Page.DataContext>

    <Grid Background="{DynamicResource WindowBackground}">
        <StackPanel Margin="20">
            <Border Background="{DynamicResource CardBackground}" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                <DockPanel>
                    <TextBlock Text="{Binding CurrentUser.Name}" Foreground="{DynamicResource MainTextBrush}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding CurrentUser.Score, StringFormat='Бали: {0}'}" Foreground="#1A73E8" HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>

            <TextBlock Text="{Binding ActiveQuestionText}" FontSize="22" Foreground="{DynamicResource MainTextBrush}"
                       TextWrapping="Wrap" Margin="0,20" TextAlignment="Center"/>

            <TextBox x:Name="AnswerInput" Style="{StaticResource ModernTextBoxStyle}"
                     Margin="0,10" KeyDown="AnswerInput_KeyDown"/>

            <TextBlock x:Name="StatusText" FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="CheckBtn" Content="ПЕРЕВІРИТИ" Click="CheckBtn_Click"
                        Style="{StaticResource MainButtonStyle}" Background="#34A853" Margin="5"/>
                <Button x:Name="NextBtn" Content="НАСТУПНЕ" Click="NextBtn_Click"
                        Style="{StaticResource MainButtonStyle}" Background="#FBBC05" Margin="5" IsEnabled="False"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>