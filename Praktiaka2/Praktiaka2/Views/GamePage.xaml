<Page x:Class="Praktiaka2.Views.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Praktiaka2.ViewModels"
      Title="Гра">

    <Page.DataContext>
        <vm:QuestViewModel/>
    </Page.DataContext>

    <Grid Background="#F0F2F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">

            <TextBlock Text="Запитання квесту" 
                       FontSize="22" FontWeight="Bold" Margin="0,0,0,20" 
                       HorizontalAlignment="Center" Foreground="#1A73E8"/>

            <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                <TextBlock Text="{Binding ActiveQuestionText}" 
                           FontSize="18" TextWrapping="Wrap" TextAlignment="Center"/>
            </Border>

            <TextBox x:Name="AnswerInput" Height="35" Margin="0,0,0,20" FontSize="16" VerticalContentAlignment="Center"/>

            <Button Content="Відповісти" Width="150" Height="40" 
                    Background="#1A73E8" Foreground="White" FontWeight="Bold"/>

        </StackPanel>
    </Grid>
</Page>