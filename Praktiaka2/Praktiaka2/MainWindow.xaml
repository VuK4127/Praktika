<Window x:Class="Praktiaka2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Квест: Наша мова" Height="450" Width="450">
    <Grid Background="#F0F2F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">

            <TextBlock Text="Квест: Наша мова — серце України" 
                       FontSize="22" FontWeight="Bold" Margin="0,0,0,20" 
                       HorizontalAlignment="Center" Foreground="#1A73E8"/>

            <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                <TextBlock x:Name="QuestionDisplay" 
                           Text="Тут буде ваше запитання..." 
                           FontSize="16" TextWrapping="Wrap" TextAlignment="Center"/>
            </Border>

            <TextBlock Text="Ваше ім'я:" Margin="0,5,0,2"/>
            <TextBox x:Name="UserNameInput" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

            <TextBlock Text="Ваша відповідь:" Margin="0,5,0,2"/>
            <TextBox x:Name="UserAnswerInput" Height="30" Margin="0,0,0,20" VerticalContentAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="StartBtn" Content="Старт" Width="100" Height="35" Margin="5" 
                        Background="#34A853" Foreground="White" Click="StartBtn_Click"/>

                <Button x:Name="CheckBtn" Content="Перевірити" Width="100" Height="35" Margin="5" 
                        Background="#1A73E8" Foreground="White" Click="CheckBtn_Click"/>

                <Button x:Name="NextBtn" Content="Наступне" Width="100" Height="35" Margin="5" 
                        Background="#FBBC05" Foreground="White" Click="NextBtn_Click"/>
            </StackPanel>

            <TextBlock x:Name="StatusMessage" Margin="0,15,0,0" 
                       HorizontalAlignment="Center" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>